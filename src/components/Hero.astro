---
import Badge from "../components/Badge.astro";
import MailIcon from "../components/icons/MailIcon.astro";
import XingIcon from "../components/icons/XingIcon.astro";
import SocialPill from "../components/SocialPill.astro";
import GitHubIcon from "./icons/GitHubIcon.astro";
import LinkedInIcon from "./icons/LinkedInIcon.astro";
import ResumeIcon from "./icons/ResumeIcon.astro";
---

<div class="flex gap-4 mb-4 pointer-events-none">
  <Badge>Available to work</Badge>
</div>
<h1
  class="text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl dark:text-white"
>
  Hey, I'm Alexandre
</h1>
<div class="hero">
  <p class="green">
    <strong>Full-Stack Developer</strong> specializing in <strong
      >E-commerce/ERP Integration</strong
    >, <strong>AI-Powered Automation</strong>, and <strong
      >Cross-Platform Mobile Development</strong
    >. MBA in Software Engineering (USP) and <strong
      >GCP Certified Associate Cloud Engineer</strong
    >.<br /><br />
    Building scalable web & mobile systems with <strong>TypeScript</strong> across
    <strong>NestJS</strong>, <strong>Vue.js/Nuxt.js</strong>, <strong
      >Svelte/SvelteKit</strong
    >, and <strong>Flutter</strong>. Expert in <strong>PostgreSQL</strong>, <strong
      >Drizzle ORM</strong
    >, <strong>BullMQ/Redis</strong> for asynchronous processing, and <strong
      >AI workflow automation</strong
    > with n8n and LLM orchestration.
  </p>
</div>

<nav class="flex flex-wrap gap-4 mt-8">
  <SocialPill
    href="https://bucket.spindola.me/cv/CV-Alexandre-Spindola-english-2026-01-30.pdf"
  >
    🇬🇧 CV - English
  </SocialPill>
  <SocialPill
    href="https://bucket.spindola.me/cv/CV-Alexandre-Spindola-spanish-2026-02-01.pdf"
  >
    🇪🇸 CV - Español
  </SocialPill>
  <SocialPill href="https://www.linkedin.com/in/alexspindola">
    <LinkedInIcon class="size-4" />
    LinkedIn
  </SocialPill>
  <SocialPill href="https://www.xing.com/profile/Alexandre_Spindola">
    <XingIcon class="size-4" />
    Xing
  </SocialPill>
  <SocialPill href="https://github.com/alexandrespindola/">
    <GitHubIcon class="size-4" />
    GitHub
  </SocialPill>
  <SocialPill href="mailto:alexandre@spindola.me">
    <MailIcon class="size-4" />
    Contact
  </SocialPill>
</nav>

<style>
  .hero p {
    @apply mt-6 text-xl text-gray-800 [&>strong]:font-semibold dark:text-gray-300;
  }

  .green {
    @apply dark:[&>strong]:text-primary [&>strong]:text-secondary;
  }
</style>

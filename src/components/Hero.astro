---
import Badge from "../components/Badge.astro";
import MailIcon from "../components/icons/MailIcon.astro";
import XingIcon from "../components/icons/XingIcon.astro";
import SocialPill from "../components/SocialPill.astro";
import GitHubIcon from "./icons/GitHubIcon.astro";
import LinkedInIcon from "./icons/LinkedInIcon.astro";
---

<div class="flex gap-4 mb-4 pointer-events-none">
  <Badge>Senior n8n Developer</Badge>
</div>
<h1
  class="text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl dark:text-white"
>
  Hey, I'm Alexandre
</h1>
<div class="hero">
  <p class="green">
    <strong>Senior AI Automation Engineer and Full Stack</strong> with an MBA in
    Software Engineering, crafting intelligent solutions that bridge the gap between
    complex business challenges and elegant automation. I build production systems
    with <strong>TypeScript</strong>, <strong>NestJS</strong>, and <strong
      >n8n workflows</strong
    >, leveraging modern frameworks like <strong>Vue.js/Nuxt.js</strong>, <strong
      >Svelte</strong
    >, and <strong>Hono</strong> to create seamless user experiences. Specialized
    in <strong>AI automation</strong>, <strong>browser automation</strong>, and <strong
      >scalable full-stack architecture</strong
    > that powers enterprise-grade solutions. <strong>GCP Certified</strong> cloud
    engineer ready for production deployments.
  </p>
</div>

<nav class="flex flex-wrap gap-4 mt-8">
  <SocialPill
    href="https://bucket.spindola.me/cv/CV-EN-ALEXANDRE-BORGES-SPINDOLA-Full-Stack-Developer-Node-24-02-2026.pdf"
  >
    🇬🇧 CV - English
  </SocialPill>
  <SocialPill
    href="https://bucket.spindola.me/cv/CV-ES-ALEXANDRE-BORGES-SPINDOLA-Full-Stack-Developer-Node-24-02-2026.pdf"
  >
    🇪🇸 CV - Español
  </SocialPill>
  <SocialPill href="https://www.linkedin.com/in/alexspindola">
    <LinkedInIcon class="size-4" />
    LinkedIn
  </SocialPill>
  <SocialPill href="https://www.xing.com/profile/Alexandre_Spindola">
    <XingIcon class="size-4" />
    Xing
  </SocialPill>
  <SocialPill href="https://github.com/alexandrespindola/">
    <GitHubIcon class="size-4" />
    GitHub
  </SocialPill>
  <SocialPill href="mailto:alexandre@spindola.me">
    <MailIcon class="size-4" />
    Contact
  </SocialPill>
</nav>

<style>
  .hero p {
    @apply mt-6 text-xl text-gray-800 [&>strong]:font-semibold dark:text-gray-300;
  }

  .green {
    @apply dark:[&>strong]:text-primary [&>strong]:text-secondary;
  }
</style>
